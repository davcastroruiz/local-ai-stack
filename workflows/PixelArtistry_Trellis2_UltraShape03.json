        }
      },
      "widgets_values": [
        "in case this node errors for you, make sure to update Trellis2 to the latest version by running the Trellis2 (requires Torch 2.8.0+cu128).bat file in the addons folder"
      ],
      "color": "#432",
      "bgcolor": "#653"
    },
